# LiveFabric Broadcast Box — runtime config
# Copied to /opt/livefabric-bb/broadcast-box.env, loaded by systemd unit.
# NOTE: DISABLE_FRONTEND must be UNSET (or absent) to enable the GUI.
#       Any non-empty value (including "FALSE") disables it.

HTTP_ADDRESS=:8080
NETWORK_TEST_ON_START=false

FRONTEND_PATH=/opt/livefabric-bb/src/web/build
FRONTEND_ADMIN_TOKEN=livefabric-admin

# Pipe-separated list of every IP a WebRTC client might route to this host on.
# Add a public IP here when port-forwarding from a router.
# IMPORTANT: do NOT include unreachable IPs (e.g. a Wi-Fi address on a different
# subnet from your viewers) — browsers may try them first and fail playback.
NAT_1_TO_1_IP=192.168.98.151

# Multiplex all WebRTC media on a single UDP port — same as HTTP for simplicity.
UDP_MUX_PORT=8080

# Dual-NIC hosts: pin WebRTC to the interface clients route to and force IPv4.
# Without this, Pion may gather candidates on a second NIC (e.g. Wi-Fi) and ICE
# checks fail intermittently. Adjust the interface name to match your host.
NETWORK_TYPES=udp4
INTERFACE_FILTER=enx9c69d33d0d8c

STREAM_PROFILE_PATH=/opt/livefabric-bb/profiles
STUN_SERVERS=stun.l.google.com:19302

LOGGING_ENABLED=TRUE
LOGGING_DIRECTORY=/opt/livefabric-bb/logs
